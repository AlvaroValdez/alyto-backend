# ==========================================
# Configuración Principal
# ==========================================
PORT=5000
NODE_ENV=production
PUBLIC_URL=https://api.alyto.app

# ==========================================
# Base de Datos (MongoDB Atlas - clúster avf_db)
# ==========================================
# Reemplaza <usuario>, <password> y <id-cluster> con los valores reales.
# IMPORTANTE: Asegúrate de que la DB sea "alyto"
MONGO_URI=mongodb+srv://<usuario>:<password>@avf-db.<id-cluster>.mongodb.net/alyto?retryWrites=true&w=majority

# ==========================================
# Seguridad y Autenticación
# ==========================================
JWT_SECRET=tu_secreto_jwt_muy_seguro_y_largo
JWT_EXPIRES_IN=1d

# ==========================================
# Integración Vita Wallet (Pagos y Retiros)
# ==========================================
VITA_API_URL=https://api.vitawallet.io
VITA_LOGIN=tu_login_de_produccion
VITA_TRANS_KEY=tu_trans_key_de_produccion
VITA_SECRET=tu_secreto_hmac_de_produccion
VITA_BUSINESS_WALLET_UUID=tu_wallet_uuid_de_produccion
VITA_NOTIFY_URL=https://api.alyto.app/api/ipn/vita

# ==========================================
# Integración Fintoc (Direct Pay)
# ==========================================
FINTOC_API_URL=https://api.fintoc.com/v1
FINTOC_SECRET_KEY=sk_live_xxxxxxxxx
FINTOC_WEBHOOK_SECRET=whsec_xxxxxxxxx

# Variables opcionales para transferencias Fintoc directas
FINTOC_RECIPIENT_HOLDER_ID=11111111-1
FINTOC_RECIPIENT_ACCOUNT_NUMBER=123456789
FINTOC_RECIPIENT_ACCOUNT_TYPE=checking_account

# ==========================================
# Integración Cloudinary (KYC, Comprobantes)
# ==========================================
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ==========================================
# Correo Transaccional (Resend)
# ==========================================
RESEND_API_KEY=re_xxxxxxxxx
EMAIL_FROM=noreply@alyto.app

# ==========================================
# FireBase / FCM (Notificaciones Push)
# ==========================================
# String JSON en una sola línea del Service Account
FIREBASE_SERVICE_ACCOUNT='{"type": "service_account", "project_id": "...", ...}'

# ==========================================
# Información de Empresa (Recibos / Emails)
# ==========================================
COMPANY_LEGAL_NAME="Alyto S.R.L."
COMPANY_NIT=123456789
COMPANY_ADDRESS="Dirección de la Empresa"
COMPANY_PHONE="+591 2 211-0000"
COMPANY_EMAIL="soporte@alyto.app"
COMPANY_WEBSITE="www.alyto.app"
